<?php
$baseDir = '/var/www/html';
$file = $baseDir . '/data.json';
$uploadDir = '/icons/';
$bgFile = $baseDir . '/backgrounds/daily.jpg';

if (!is_dir($baseDir . $uploadDir)) mkdir($baseDir . $uploadDir, 0755, true);
if (!is_dir($baseDir . '/backgrounds/')) mkdir($baseDir . '/backgrounds/', 0755, true);

if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_GET['action'])) {
    header('Content-Type: application/json');
    $raw = file_get_contents('php://input');

    if ($_GET['action'] === 'save') {
        $decoded = json_decode($raw, true);
        if (json_last_error() !== JSON_ERROR_NONE || !is_array($decoded)) {
            echo json_encode(['status' => 'error']); exit;
        }

        // ✅ 核心修复：eMMC 防重复读写优化
        $oldRaw = file_exists($file) ? file_get_contents($file) : '';
        if ($raw === $oldRaw) {
            echo json_encode(['status' => 'no_change']); 
            exit; // 数据未变，直接返回，保护磁盘
        }

        file_put_contents($file, $raw, LOCK_EX);
        echo json_encode(['status' => 'ok']);
    } 
    elseif ($_GET['action'] === 'fetch_icon') {
        $target = json_decode($raw, true)['url'] ?? '';
        if (!preg_match('~^https?://~i', $target)) {
            $target = (preg_match('/^\d+$/', $target)) ? 'http://127.0.0.1:' . $target : 'http://' . $target;
        }
        $opts = ['http'=>['header'=>"User-Agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64)\r\n",'timeout'=>8], 'ssl'=>["verify_peer"=>false,"verify_peer_name"=>false]];
        $ctx = stream_context_create($opts);
        $html = @file_get_contents($target, false, $ctx);
        $p = parse_url($target);
        $baseUrl = ($p['scheme']??'http') . '://' . ($p['host']??'') . (isset($p['port'])?':'.$p['port']:'');
        $ico = '';
        if ($html) {
            if (preg_match('/<link.*?rel=["\'](?:apple-touch-icon|icon|shortcut icon)["\'].*?href=["\'](.*?)["\']/i', $html, $m)) $ico = $m[1];
        }
        if (!$ico) $ico = $baseUrl . '/favicon.ico';
        if ($ico && !preg_match('~^https?://|data:~i', $ico)) {
            if (strpos($ico, '//') === 0) $ico = ($p['scheme']??'http') . ':' . $ico;
            elseif (strpos($ico, '/') === 0) $ico = $baseUrl . $ico;
            else $ico = rtrim($target, '/') . '/' . $ico;
        }
        $img = @file_get_contents($ico, false, $ctx);
        if ($img) {
            $n = 'fav_'.time().'.png';
            file_put_contents($baseDir.$uploadDir.$n, $img);
            echo json_encode(['status' => 'ok', 'path' => $uploadDir.$n]);
        } else { echo json_encode(['status' => 'error']); }
        exit;
    }
    elseif ($_GET['action'] === 'upload') {
        if (isset($_FILES['image'])) {
            $n = 'up_'.time().'.'.pathinfo($_FILES['image']['name'], PATHINFO_EXTENSION);
            if(move_uploaded_file($_FILES['image']['tmp_name'], $baseDir . $uploadDir . $n)) {
                echo json_encode(['status' => 'ok', 'path' => $uploadDir . $n]);
            }
        }
        exit;
    }
    elseif ($_GET['action'] === 'update_bg') {
        $api = "https://www.bing.com/HPImageArchive.aspx?format=js&idx=0&n=1&mkt=zh-CN";
        $d = json_decode(@file_get_contents($api), true);
        if (isset($d['images'][0]['url'])) {
            $img = @file_get_contents("https://www.bing.com" . $d['images'][0]['url']);
            if ($img) { file_put_contents($bgFile, $img); echo json_encode(['status' => 'ok']); exit; }
        }
        echo json_encode(['status' => 'error']); exit;
    }
    exit;
}
$db = [["name" => "默认", "items" => []]];
if (file_exists($file)) $db = json_decode(file_get_contents($file), true) ?: $db;
?>
