<?php
/**
 * Server Manager V5.0 - 核心文件操作增强版
 */
$paths = [
    'mihomo_bin'    => '/opt/mihomo/mihomo',
    'mihomo_config' => '/etc/mihomo/',
    'geoip'         => '/etc/mihomo/geoip.metadb',
    'geosite'       => '/etc/mihomo/geosite.dat',
    'ipv6'          => '/etc/mihomo/china_ipv6.txt',
    'ui_dir'        => '/var/www/html/dashboard/'
];

$config_file = './manager_settings.json';
$settings = file_exists($config_file) ? json_decode(file_get_contents($config_file), true) : ['proxy' => ''];

function downloadWithCurl($url, $proxy) {
    $ch = curl_init();
    curl_setopt_array($ch, [
        CURLOPT_URL => $url,
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_FOLLOWLOCATION => true,
        CURLOPT_TIMEOUT => 600,
        CURLOPT_USERAGENT => 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
        CURLOPT_SSL_VERIFYPEER => false
    ]);
    if (!empty($proxy)) curl_setopt($ch, CURLOPT_PROXY, $proxy);
    $data = curl_exec($ch);
    $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
    curl_close($ch);
    if ($httpCode === 200 && $data) return $data;
    throw new Exception("下载失败: HTTP $httpCode");
}

if (isset($_GET['action'])) {
    header('Content-Type: application/json');
    $action = $_GET['action'];
    $proxy = $settings['proxy'] ?: null;
    try {
        // 1. 获取 Release 列表
        if ($action === 'get_releases') {
            $repo = $_GET['repo'];
            $data = downloadWithCurl("https://api.github.com/repos/$repo/releases", $proxy);
            $res = json_decode($data, true);
            $output = [];
            if(is_array($res)){
                foreach ($res as $rel) {
                    foreach ($rel['assets'] as $asset) {
                        $name = $asset['name'];
                        if ($repo === 'MetaCubeX/mihomo' && strpos($name, 'linux-arm64') !== false && strpos($name, '.gz') !== false) {
                            $output[] = ['tag' => $rel['tag_name'], 'url' => $asset['browser_download_url'], 'name' => $name];
                        } else if ($repo === 'MetaCubeX/metacubexd' && strpos($name, 'compressed-dist.tgz') !== false) {
                            $output[] = ['tag' => $rel['tag_name'], 'url' => $asset['browser_download_url'], 'name' => "UI: $name"];
                        }
                    }
                }
            }
            echo json_encode($output);
        }

        // 2. 更新内核 (GZ -> Binary)
        if ($action === 'update_bin') {
            $data = downloadWithCurl($_POST['url'], $proxy);
            $tmp_gz = "/tmp/mihomo.gz"; $tmp_bin = "/tmp/mihomo_new";
            file_put_contents($tmp_gz, $data);
            
            // 解压并赋予权限
            exec("gzip -dfc $tmp_gz > $tmp_bin && chmod +x $tmp_bin");
            
            // 物理替换流程
            exec("sudo systemctl stop mihomo 2>/dev/null");
            exec("sudo rm -f {$paths['mihomo_bin']}");
            exec("sudo mv $tmp_bin {$paths['mihomo_bin']}");
            exec("sudo chmod +x {$paths['mihomo_bin']}");
            exec("sudo systemctl start mihomo");
            
            unlink($tmp_gz);
            echo json_encode(['status' => 'success', 'msg' => '内核更新完成，服务已重启']);
        }

        // 3. 更新面板 (TGZ -> Dashboard)
        if ($action === 'update_ui') {
            $data = downloadWithCurl($_POST['url'], $proxy);
            $tmp_tgz = "/tmp/ui.tgz";
            file_put_contents($tmp_tgz, $data);
            
            // 确保目录存在并清空
            if (!is_dir($paths['ui_dir'])) exec("sudo mkdir -p {$paths['ui_dir']}");
            exec("sudo rm -rf {$paths['ui_dir']}*");
            
            // 解压面板文件 (不改 Nginx 配置)
            exec("sudo tar -xzvf $tmp_tgz -C {$paths['ui_dir']} --strip-components=1", $out, $ret);
            if ($ret !== 0) exec("sudo tar -xzvf $tmp_tgz -C {$paths['ui_dir']}");
            
            exec("sudo chown -R www-data:www-data {$paths['ui_dir']}");
            unlink($tmp_tgz);
            echo json_encode(['status' => 'success', 'msg' => '面板文件已替换，刷新 8081 即可查看']);
        }

        // 4. 服务控制 (仅针对 Mihomo)
        if ($action === 'service') {
            $cmd = $_POST['cmd'];
            exec("sudo systemctl $cmd mihomo");
            echo json_encode(['status'=>'success', 'msg'=>"Mihomo 服务已执行 $cmd"]);
        }

        // 5. 规则库同步
        if ($action === 'update_file') {
            $urls = ['geoip'=>'https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip.metadb','geosite'=>'https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geosite.dat','ipv6'=>'https://raw.githubusercontent.com/gaoyifan/china-operator-ip/ip-lists/china6.txt'];
            $data = downloadWithCurl($urls[$_POST['type']], $proxy);
            file_put_contents($paths[$_POST['type']], $data);
            echo json_encode(['status' => 'success', 'msg' => '规则文件已同步']);
        }

        // 6. 代理保存
        if ($action === 'save_proxy') {
            $settings['proxy'] = $_POST['proxy'];
            file_put_contents($config_file, json_encode($settings));
            echo json_encode(['status'=>'success', 'msg'=>'代理配置已保存']);
        }
    } catch (Exception $e) { echo json_encode(['status' => 'error', 'msg' => $e->getMessage()]); }
    exit;
}
