    <script>
        function notify(msg, type = 'success') {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toast-icon');
            const msgEl = document.getElementById('toast-msg');
            msgEl.innerText = msg;
            icon.className = `w-10 h-10 rounded-full flex items-center justify-center text-white shadow-lg ${type === 'success' ? 'bg-emerald-500' : 'bg-rose-500'}`;
            icon.innerHTML = type === 'success' ? '<i class="fas fa-check"></i>' : '<i class="fas fa-times"></i>';
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        async function callAction(btn, action, data = {}) {
            const originalHTML = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin text-[10px]"></i>';
            const fd = new FormData();
            for (let k in data) fd.append(k, data[k]);
            try {
                const r = await fetch(`?action=${action}`, {method: 'POST', body: fd});
                const d = await r.json();
                notify(d.msg, d.status);
            } catch (e) { notify('请求出错', 'error'); }
            btn.disabled = false; btn.innerHTML = originalHTML;
        }

        function showTab(id) {
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.sidebar-item').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + id).classList.add('active');
            document.getElementById('btn-' + id).classList.add('active');
        }

        async function fetchList(btn, type) {
            const repo = (type === 'mihomo') ? 'MetaCubeX/mihomo' : 'MetaCubeX/metacubexd';
            btn.disabled = true;
            const original = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            try {
                const res = await fetch(`?action=get_releases&repo=${repo}`);
                const data = await res.json();
                const select = document.getElementById(type === 'mihomo' ? 'bin-select' : 'ui-select');
                select.innerHTML = data.map(item => `<option value="${item.url}">${item.tag} - ${item.name}</option>`).join('');
                notify(`抓取成功 (${data.length})`);
            } catch (e) { notify('GitHub 获取失败', 'error'); }
            btn.disabled = false; btn.innerHTML = original;
        }

        function updateBinary(btn) {
            const url = document.getElementById('bin-select').value;
            if(!url) return notify('请先获取版本', 'error');
            callAction(btn, 'update_bin', {url: url});
        }

        function updateUI(btn) {
            const url = document.getElementById('ui-select').value;
            if(!url) return notify('请先获取版本', 'error');
            callAction(btn, 'update_ui', {url: url});
        }
    </script>
